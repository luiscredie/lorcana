{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "lorcana",
  "main": "worker.js",
  "compatibility_date": "2026-07-09",
  "observability": {
    "enabled": true
  },
  "vars": {
    "GITHUB_OWNER": "luiscredie",
    "GITHUB_REPO": "lorcana",
    "GITHUB_BRANCH": "main",
    "GITHUB_PATH": "atlas-data.json",
    "ALLOWED_ORIGIN": "https://luiscredie.github.io"
  }
}